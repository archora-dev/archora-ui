{
  "name": "archora-ui",
  "version": "0.0.0",
  "private": true,
  "description": "Dark-first Vue 3 design system for premium dashboards and internal tools.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "dev": "corepack pnpm dev:docs",
    "build": "corepack pnpm -r build",
    "build:ui": "corepack pnpm --filter @archora/ui build",
    "build:docs": "corepack pnpm --filter @archora/docs build",
    "dev:docs": "corepack pnpm --filter @archora/docs dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "corepack pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "stylelint": "stylelint \"**/*.{css,vue}\""
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "@eslint/js": "^9.26.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.26.0",
    "eslint-plugin-vue": "^9.33.0",
    "jsdom": "^26.1.0",
    "postcss-html": "^1.8.0",
    "prettier": "^3.5.3",
    "playwright": "^1.59.1",
    "stylelint": "^16.19.1",
    "stylelint-config-standard": "^38.0.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0",
    "vite": "^5.4.21",
    "vitepress": "^1.6.3",
    "vitest": "^3.1.3",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.10"
  }
}
